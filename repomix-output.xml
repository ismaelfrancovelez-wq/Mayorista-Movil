  const TABS = [
    { id: "streak"    as const, label: "Racha de lotes", color: "#2090e0", emoji: "⚡" },
    { id: "milestone" as const, label: "Logros",          color: "#d0a030", emoji: "🏆" },
    { id: "level"     as const, label: "Nivel",           color: "#40b860", emoji: "🎖️" },
