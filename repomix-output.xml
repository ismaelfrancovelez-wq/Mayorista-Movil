    </ul>
  </div>
  <p style="text-align:center;">
    <a href="https://mayoristamovil.com/explorar" style="display:inline-block;background:#2563eb;color:white;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:600;">
