// ─── BADGE DATA ────────────────────────────────────────────────────────────────
const STREAK_BADGES_DATA: { id: string; label: string; streak: number; tier: number }[] = [
  { id: "streak_start",     label: "Primer Vínculo", streak: 1,  tier: 1 },
